# =============================================================================
# MultiSubs Infra — Environment Variables
# =============================================================================

# ── Blockchain ──────────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org
CHAIN_ID=84532

# ── Pre-deployment Addresses (set before running deployment scripts) ─────────
# M1 Treasury Safe (pre-deployed, or deployed by DeployTestnet)
M1_SAFE_ADDRESS=
# Settlement service backend EOA
SETTLER_ADDRESS=
# Yield manager service backend EOA
YIELD_OPERATOR_ADDRESS=
# Platform Issuer Safe that receives settlement funds
PLATFORM_ISSUER_SAFE_ADDRESS=
# USDC token address (Base Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e, Base Mainnet: 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913)
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Morpho vault address (Steakhouse Prime USDC on Base)
MORPHO_VAULT_ADDRESS=
# Aave v3 pool address on Base (optional, set to 0x0 to skip)
AAVE_POOL_ADDRESS=
# Safe v1.4.1 singleton address on Base
SAFE_SINGLETON_ADDRESS=
# Zodiac Roles v2 singleton on Base (address(0) to skip)
ROLES_MODULE_ADDRESS=0x0000000000000000000000000000000000000000
# Zodiac Delay singleton on Base (address(0) to skip)
DELAY_MODULE_ADDRESS=0x0000000000000000000000000000000000000000

# ── Optional: Initial Tenant Registration ───────────────────────────────────
# INITIAL_TENANT_ID=  (bytes32 hex string)
# INITIAL_TENANT_SAFE=  (address)

# ── Contract Addresses (populated after deployment) ─────────────────────────
SPEND_SETTLER_ADDRESS=
SPEND_SETTLER_IMPL_ADDRESS=
M1_TREASURY_ADDRESS=
MODULE_SETUP_HELPER_ADDRESS=
TENANT_REGISTRY_ADDRESS=
SAFE_FACTORY_ADDRESS=
DEFI_INTERACTOR_ADDRESS=
TREASURY_VAULT_ADDRESS=

# ── Deployer ────────────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=
SETTLER_PRIVATE_KEY=
BASESCAN_API_KEY=

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://multisubs:multisubs@localhost:5432/multisubs

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ── Lithic ──────────────────────────────────────────────────────────────────
LITHIC_API_KEY=
LITHIC_WEBHOOK_SECRET=
LITHIC_ENVIRONMENT=sandbox

# ── Watcher ─────────────────────────────────────────────────────────────────
WATCHER_POLL_INTERVAL_MS=3000
WATCHER_START_BLOCK=0

# ── Settlement ──────────────────────────────────────────────────────────────
SETTLEMENT_MAX_RETRIES=3
SETTLEMENT_GAS_BUMP_PERCENT=20
