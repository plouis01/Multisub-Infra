# =============================================================================
# MultiSubs Infra — Environment Variables
# =============================================================================

# ── Blockchain ──────────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org
CHAIN_ID=84532

# ── Contract Addresses (populated after deployment) ─────────────────────────
SPEND_SETTLER_ADDRESS=
M1_TREASURY_ADDRESS=
PLATFORM_ISSUER_SAFE_ADDRESS=
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ── Deployer ────────────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=
SETTLER_PRIVATE_KEY=
BASESCAN_API_KEY=

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://multisubs:multisubs@localhost:5432/multisubs

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173

# ── Lithic ──────────────────────────────────────────────────────────────────
LITHIC_API_KEY=
LITHIC_WEBHOOK_SECRET=
LITHIC_ENVIRONMENT=sandbox

# ── Watcher ─────────────────────────────────────────────────────────────────
WATCHER_POLL_INTERVAL_MS=3000
WATCHER_START_BLOCK=0

# ── Settlement ──────────────────────────────────────────────────────────────
SETTLEMENT_MAX_RETRIES=3
SETTLEMENT_GAS_BUMP_PERCENT=20
